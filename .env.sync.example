# Template for scripts/sync-college-explorer.sh (local/manual sync only -
# this file is NOT read by the GitHub Actions workflow, which uses repo
# secrets instead - see docs/github-secrets-setup.md).
#
# Copy this file to .env.sync and fill in real values:
#   cp .env.sync.example .env.sync
#
# .env.sync is gitignored - never commit real tokens.

# HTTPS URL of the client's Lovable GitHub repo.
LOVABLE_REPO_URL=https://github.com/Nav-o/love-spark-v2.git

# Optional: fine-grained PAT with Contents:Read on the Lovable repo.
# Only needed if the Lovable repo is private.
LOVABLE_REPO_TOKEN=
